# Servidor
PORT=3000
HOST=0.0.0.0

# Supabase (PostgreSQL + pgvector)
SUPABASE_URL=https://sua-url-do-supabase.supabase.co
SUPABASE_SERVICE_ROLE_KEY=seu-service-role-key-confidencial
SUPABASE_ANON_KEY=sua-anon-public-key

# Inteligência Artificial (LLM & Embeddings)
# Donna usa Claude para raciocínio tático e OpenAI para embeddings (ou outros provedores)
ANTHROPIC_API_KEY=sua-chave-api-da-anthropic-aqui
OPENAI_API_KEY=sua-chave-api-da-openai-aqui (necessário para text-embedding-3-small)

# Notificações
# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://sua-url-da-evolution.com
EVOLUTION_API_KEY=sua-chave-global-da-evolution
EVOLUTION_INSTANCE_NAME=donna_whatsapp

# Resend (E-mail)
RESEND_API_KEY=re_suachaveaqui
EMAIL_REMETENTE=donna@seu-dominio.com.br

# PJe MCP Server (DT-03: nunca usar path hardcoded no código)
# Caminho absoluto ou relativo ao processo Node para o servidor MCP compilado
PJE_MCP_SERVER_PATH=./services/pje-mcp-server/build/index.js

# Autenticação JWT (DT-04)
# Mesmo JWT_SECRET configurado no Supabase Auth (Settings > API > JWT Secret)
JWT_SECRET=seu-jwt-secret-do-supabase-aqui

# CORS — Lista de origens permitidas em produção (DT-CORS)
ALLOWED_ORIGINS=https://app.donna.com.br,https://admin.donna.com.br

# Frontend Next.js — variáveis públicas (prefixo NEXT_PUBLIC_ obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://sua-url-do-supabase.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-public-key
NEXT_PUBLIC_API_URL=http://localhost:3000
