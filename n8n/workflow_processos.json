        "jsonBody": "={\n  \"from\": \"Donna <{{ $env.EMAIL_REMETENTE }}>\",\n  \"to\": [\"{{ $json.email_destinatario }}\"],\n  \"subject\": \"🚨 Donna Alerta: {{ $json.titulo_alerta }}\",\n  \"html\": \"{{ $json.corpo_email_html }}\"\n}",
